# Copy this file to .env and fill in your values
# Never commit .env to version control

# Database
DB_USERNAME=plasticwatch
DB_PASSWORD=your_secure_password_here

# JWT — must be at least 32 characters
JWT_SECRET=YourSuperSecretJWTKeyThatIsAtLeast256BitsLong

# File storage
UPLOAD_DIR=./uploads
BASE_URL=http://plastic-watch-backend.onrender.com/api

# Google Maps (used in Flutter — set in AndroidManifest.xml and AppDelegate.swift)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
